# Raw exported account data — real Claude website exports + Claude Code transcripts.
# May contain secrets / private code / PII. NEVER commit. Curate to the demo slice first.
data/raw/
**/data/raw/
*.tgz
*.zip

# Secrets / env
.env
backend/.env
*.local

# Python
__pycache__/
*.pyc
.venv/
venv/

# Generated embedding cache
**/embeddings.npz

# Ingested seed corpora — derived from real private conversations. Local-only;
# regenerate with scripts/ingest.py. Do NOT commit until reviewed + cleared.
backend/app/data/corpora/*.json

# Playwright MCP browser artifacts (screenshots/snapshots from local verification)
.playwright-mcp/

# Graphify code-graph output — regenerable tool artifact, not source. Local-only.
graphify-out/

# Frontend production build output — regenerable with `npm run build`. Local-only.
frontend/dist/

# design-sync: staged converter scripts, build output, and machine state.
# Durable inputs ARE committed: .design-sync/{config.json,NOTES.md,conventions.md,
# previews/,overrides/} and the bundle entry barrel frontend/.ds-bundle-entry.jsx.
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
